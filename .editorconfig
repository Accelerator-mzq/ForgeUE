# EditorConfig — https://editorconfig.org/
# Cross-IDE consistency for indent / line-ending / encoding.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
# Markdown trailing whitespace can be significant (line break)
trim_trailing_whitespace = false

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.{js,ts,html,css,scss}]
indent_size = 2

[Makefile]
indent_style = tab
