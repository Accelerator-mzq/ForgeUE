# forgeue 运行期密钥模板 —— 复制为 `.env` 后填真实值使用。
# `.env.example` 可以安全提交到仓库，`.env` 已在 .gitignore 内（别把真实 key 放这里）。
#
# 用法：
#   cp .env.example .env
#   # 编辑 .env 填入真实 key（至少填一个 provider）
#
# 本项目的 example bundle 默认把 preferred_models=["gpt-4o-mini"]、
# fallback_models=["anthropic/claude-haiku-4-5-20251001"] —— 填其中任意一个即可。
# CapabilityRouter 会先试 preferred，失败才切 fallback。
#
# 第三方代理（OpenRouter / Together / Moonshot / Minimaxi / DeepSeek / 任何
# OpenAI-或 Anthropic-兼容网关）都是"同一个 provider 变量组 + 覆盖 BASE_URL"
# 的模式：API_KEY 填代理给您的 key，API_BASE 指向代理入口。
# LiteLLM 会自动读取 <VENDOR>_API_BASE 环境变量用作 endpoint。

# =========================================================================
# OpenAI 系（走官方或 OpenAI-兼容代理，如 OpenRouter / Together / Moonshot）
# =========================================================================

OPENAI_API_KEY=sk-REPLACE-ME
# 走代理时取消下一行并替换为代理的入口。官方时保持注释即可（默认走 api.openai.com）
# OPENAI_API_BASE=https://your-openai-compatible-proxy.example.com/v1
# OPENAI_ORGANIZATION=org-...

# =========================================================================
# Anthropic 系（走官方或 Anthropic-兼容代理）
# =========================================================================

ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
# 走代理时取消下一行并指向代理。例如某家 Anthropic-兼容端口：
# ANTHROPIC_API_BASE=https://your-anthropic-compatible-proxy.example.com
# ANTHROPIC_API_VERSION=2023-06-01

# =========================================================================
# 其他 provider（需要时取消注释）
# =========================================================================

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Google Gemini
# GOOGLE_API_KEY=

# OpenRouter（LiteLLM model id: openrouter/anthropic/claude-3-haiku …）
# OPENROUTER_API_KEY=
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Together.ai（LiteLLM model id: together_ai/meta-llama/...）
# TOGETHER_API_KEY=
# TOGETHER_API_BASE=https://api.together.xyz/v1

# DeepSeek
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com

# Moonshot / Kimi
# MOONSHOT_API_KEY=
# MOONSHOT_API_BASE=https://api.moonshot.cn/v1

# =========================================================================
# 别名级独立 key —— 当 config/models.yaml 里别名声明了 api_key_env 时使用
# =========================================================================
# 每个 provider 一个独立 env var，config/models.yaml 里 api_key_env: 指向它，
# 彼此互不冲突。支持同时用多家 / 多个 Anthropic-兼容代理并存。

# --- 文本 / 视觉 LLM（国外）---
# MINIMAX_KEY=sk-cp-your-minimax-proxy-key             # MiniMax Anthropic-兼容
# PACKYCODE_KEY=sk-your-packycode-proxy-key            # PackyCode 中转
# GOOGLE_API_KEY=AIza-your-google-ai-studio-key        # Gemini 3 Flash / Pro / Imagen
# OPENAI_API_KEY=sk-your-openai-key                    # GPT-4o / DALL-E 3
# XAI_API_KEY=xai-your-grok-key                        # Grok 4

# --- 文本 / 视觉 / 图像 LLM（国内，便宜替代）---
# ZHIPU_API_KEY=your-zhipu-api-key                     # GLM-4.1V / CogView（智谱清言）
# DASHSCOPE_API_KEY=sk-your-dashscope-key              # Qwen / 通义万相（阿里云百炼）
# HUNYUAN_API_KEY=your-hunyuan-key                     # 腾讯混元文本 / 图生
# 腾讯混元生 3D —— TC3-HMAC-SHA256 需要 Secret ID + Secret Key 两把
# HUNYUAN_3D_SECRET_ID=AKID-your-tencent-cloud-secret-id
# HUNYUAN_3D_SECRET_KEY=your-tencent-cloud-secret-key
# HUNYUAN_3D_REGION=ap-singapore                       # 或 na-siliconvalley

# --- 图片生成（国外补充，可选）---
# FAL_KEY=fal-your-fal-ai-key                          # fal.ai Flux / SDXL
# REPLICATE_API_TOKEN=r8_your-replicate-key            # Replicate

# --- 3D 资产生成 ---
# TRIPO3D_KEY=tsk-your-tripo3d-key                     # Tripo3D image-to-3D

# =========================================================================
# LiteLLM 调试开关
# =========================================================================
# LITELLM_LOG=INFO              # 打开看每次请求的 URL / headers（除了 API key）
# LITELLM_DROP_PARAMS=True      # 某些代理不认的参数自动剔除，避免 400
